<div class="w-full">
  <h1 class="font-bold text-4xl mb-8">Salary Insights</h1>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
    <!-- Metrics by Country -->
    <div class="bg-white shadow rounded-lg p-6">
      <h2 class="text-xl font-semibold mb-4 border-b pb-2">Salary Metrics by Country</h2>
      <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-gray-200">
          <thead>
            <tr>
              <th class="text-left text-xs font-medium text-gray-500 uppercase">Country</th>
              <th class="text-right text-xs font-medium text-gray-500 uppercase">Min</th>
              <th class="text-right text-xs font-medium text-gray-500 uppercase">Max</th>
              <th class="text-right text-xs font-medium text-gray-500 uppercase">Average</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-200">
            <% @salary_by_country.each do |country, metrics| %>
              <tr>
                <td class="py-2 text-sm font-medium text-gray-900"><%= country %></td>
                <td class="py-2 text-sm text-right text-gray-500"><%= number_to_currency(metrics[:min]) %></td>
                <td class="py-2 text-sm text-right text-gray-500"><%= number_to_currency(metrics[:max]) %></td>
                <td class="py-2 text-sm text-right text-gray-900 font-semibold"><%= number_to_currency(metrics[:avg]) %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>

    <!-- Average Salary by Job Title in Country -->
    <div class="bg-white shadow rounded-lg p-6">
      <h2 class="text-xl font-semibold mb-4 border-b pb-2">Avg Salary by Job Title & Country</h2>
      <div class="space-y-6">
        <% @avg_salary_by_job_title_and_country.each do |country, jobs| %>
          <div>
            <h3 class="text-sm font-bold text-blue-600 uppercase tracking-wider mb-2"><%= country %></h3>
            <ul class="divide-y divide-gray-100">
              <% jobs.each do |title, avg| %>
                <li class="flex justify-between py-2 text-sm">
                  <span class="text-gray-600"><%= title %></span>
                  <span class="font-medium text-gray-900"><%= number_to_currency(avg) %></span>
                </li>
              <% end %>
            </ul>
          </div>
        <% end %>
      </div>
    </div>

    <!-- Global Average by Job Title -->
    <div class="bg-white shadow rounded-lg p-6 md:col-span-2">
      <h2 class="text-xl font-semibold mb-4 border-b pb-2">Global Average Salary by Job Title</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-4">
        <% @global_avg_by_job_title.each do |title, avg| %>
          <div class="border rounded-lg p-4 bg-gray-50">
            <p class="text-xs text-gray-500 uppercase font-medium"><%= title %></p>
            <p class="text-lg font-bold text-gray-900"><%= number_to_currency(avg) %></p>
          </div>
        <% end %>
      </div>
    </div>
  </div>

  <div class="mt-8">
    <%= link_to 'Back to Employees', employees_path, class: "rounded-lg py-3 px-5 bg-gray-100 inline-block font-medium" %>
  </div>
</div>
